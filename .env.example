# Prisma now uses PostgreSQL. For local dev you can use a local Postgres
# instance or a hosted Postgres provider such as Neon.
# Example Neon-style connection string:
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require"

# Required for Auth.js. Replace this with a long random secret before deploy.
NEXTAUTH_SECRET="change-this-before-deploying"

# Local dev origin. This still needs to be set to the exact public origin in
# production even though the app has a development-only fallback.
# Example: NEXTAUTH_URL="https://trainer.example.com"
NEXTAUTH_URL="http://localhost:3000"
